# ==========================================
# DOCKER IGNORE - ROOT LEVEL
# ==========================================
# Exclude unnecessary files from Docker build context

# Node modules (will be installed in container)
node_modules/
npm-debug.log
yarn-error.log

# Environment files (use docker-compose environment instead)
.env
.env.local
.env.*.local

# Git files
.git/
.gitignore
.gitattributes

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
dist/
build/
.next/
out/

# Test files
coverage/
*.test.js
*.spec.js
__tests__/

# Documentation
README.md
CHANGELOG.md
LICENSE
*.md

# CI/CD
.github/
.gitlab-ci.yml
.travis.yml

# Docker files (don't copy into container)
Dockerfile
docker-compose*.yml
.dockerignore
