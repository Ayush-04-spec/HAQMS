# ==========================================
# HAQMS PRODUCTION ENVIRONMENT TEMPLATE
# ==========================================
# Copy this file to .env.production and update with your values
# DO NOT commit .env.production to version control

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
POSTGRES_USER=haqms_user
POSTGRES_PASSWORD=CHANGE_THIS_TO_SECURE_PASSWORD
POSTGRES_DB=haqms_production

# Full database connection string
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}

# ==========================================
# BACKEND CONFIGURATION
# ==========================================
# JWT Secret for authentication (generate with: openssl rand -base64 32)
JWT_SECRET=CHANGE_THIS_TO_SECURE_JWT_SECRET

# Node environment
NODE_ENV=production

# Backend port
PORT=5000

# ==========================================
# FRONTEND CONFIGURATION
# ==========================================
# API endpoint (update to your production domain)
NEXT_PUBLIC_API_BASE_URL=http://localhost:5000/api

# For production with custom domain:
# NEXT_PUBLIC_API_BASE_URL=https://api.yourdomain.com/api

# ==========================================
# SECURITY NOTES
# ==========================================
# 1. Generate secure passwords:
#    openssl rand -base64 24
#
# 2. Generate secure JWT secret:
#    openssl rand -base64 32
#
# 3. Update NEXT_PUBLIC_API_BASE_URL to your production domain
#
# 4. Never commit this file to version control
#
# 5. Restrict file permissions:
#    chmod 600 .env.production
